---
import { site, nav } from '../data/site.ts';
import SocialLinks from './SocialLinks.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => (base + href).replace(/\/{2,}/g, '/') || '/';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <span class="footer__name">{site.name}</span>
      <span class="footer__role">{site.role}</span>
    </div>

    <nav class="footer__nav" aria-label="Footer">
      {nav.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
    </nav>

    <SocialLinks />
  </div>
  <div class="container footer__bottom">
    <p>© {year} {site.copyrightHolder}. All rights reserved.</p>
    <p class="footer__built">Built with Astro · Hosted on GitHub Pages</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    background: var(--paper-soft);
    margin-top: auto;
  }
  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 2.5rem;
    align-items: center;
    justify-content: space-between;
    padding-block: 2.75rem;
  }
  .footer__brand {
    display: flex;
    flex-direction: column;
  }
  .footer__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
  }
  .footer__role {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }
  .footer__nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  .footer__nav a {
    font-family: var(--font-display);
    color: var(--ink);
    font-size: 0.92rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .footer__nav a:hover {
    color: var(--forest);
  }
  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    justify-content: space-between;
    padding-block: 1.25rem;
    border-top: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
  .footer__bottom p {
    margin: 0;
  }
</style>
