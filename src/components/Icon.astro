---
// Minimal inline-SVG icon set (no external icon library / network calls).
// Add more entries to `paths` as needed.
interface Props {
  name:
    | 'linkedin'
    | 'scholar'
    | 'researchgate'
    | 'orcid'
    | 'email'
    | 'arrow-right'
    | 'arrow-left'
    | 'chevron-left'
    | 'chevron-right'
    | 'sun'
    | 'moon';
  size?: number;
  class?: string;
}
const { name, size = 20, class: className } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  focusable="false"
>
  {name === 'linkedin' && (
    <g stroke="none" fill="currentColor">
      <path
        d="M4.98 3.5A2.5 2.5 0 1 1 2.5 6 2.5 2.5 0 0 1 4.98 3.5zM3 8.98h4v12H3v-12zM10 8.98h3.8v1.64h.05a4.17 4.17 0 0 1 3.75-2.06c4 0 4.74 2.64 4.74 6.07v6.35h-4v-5.63c0-1.34 0-3.07-1.87-3.07s-2.16 1.46-2.16 2.97v5.73H10v-12z"
      ></path>
    </g>
  )}
  {name === 'scholar' && <path d="M12 3 1 9l11 6 9-4.9V17h2V9L12 3z M4 12.5V16c0 1.7 3.6 3 8 3s8-1.3 8-3v-3.5l-8 4.4-8-4.4z" stroke="none" fill="currentColor"></path>}
  {name === 'researchgate' && (
    <text
      x="12"
      y="16"
      text-anchor="middle"
      font-size="12"
      font-family="var(--font-display)"
      font-weight="700"
      fill="currentColor"
      stroke="none">RG</text>
  )}
  {name === 'orcid' && (
    <g stroke="none" fill="currentColor">
      <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.12"></circle>
      <text
        x="12"
        y="16"
        text-anchor="middle"
        font-size="10"
        font-family="var(--font-display)"
        font-weight="700"
        fill="currentColor">iD</text>
    </g>
  )}
  {name === 'email' && (
    <>
      <rect x="3" y="5" width="18" height="14" rx="2"></rect>
      <path d="m3 7 9 6 9-6"></path>
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <path d="M5 12h14"></path>
      <path d="m13 6 6 6-6 6"></path>
    </>
  )}
  {name === 'arrow-left' && (
    <>
      <path d="M19 12H5"></path>
      <path d="m11 18-6-6 6-6"></path>
    </>
  )}
  {name === 'chevron-left' && <path d="m15 18-6-6 6-6"></path>}
  {name === 'chevron-right' && <path d="m9 18 6-6-6-6"></path>}
  {name === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4"></circle>
      <path
        d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
      ></path>
    </>
  )}
  {name === 'moon' && <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>}
</svg>
