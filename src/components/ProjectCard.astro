---
import Icon from './Icon.astro';
import { withBase, asset } from '../lib/paths.ts';

interface Props {
  id: string;
  title: string;
  summary: string;
  excerpt?: string;
  cover?: string;
  tags?: string[];
}
const { id, title, summary, excerpt, cover, tags = [] } = Astro.props;
const href = withBase(`/projects/${id}`);
const coverSrc = asset(cover);
---

<article class="card project">
  <a href={href} class="project__media" aria-label={title}>
    <div class="img-box">
      {coverSrc ? <img src={coverSrc} alt={`${title} cover`} /> : <span>&lt;IMAGE&gt;</span>}
    </div>
  </a>

  <div class="project__body">
    <h3 class="project__title"><a href={href}>{title}</a></h3>
    <p class="project__summary">{summary}</p>
    {excerpt && <p class="project__excerpt">{excerpt}</p>}

    {
      tags.length > 0 && (
        <ul class="project__tags">
          {tags.map((t) => (
            <li class="tag">{t}</li>
          ))}
        </ul>
      )
    }

    <a href={href} class="arrow-link project__more">
      Read More <Icon name="arrow-right" size={18} />
    </a>
  </div>
</article>

<style>
  .project {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.25rem, 3vw, 2.25rem);
    padding: clamp(1.25rem, 3vw, 2rem);
  }
  .project__media {
    display: block;
  }
  .project__media .img-box {
    aspect-ratio: 4 / 3;
    height: 100%;
  }
  .project__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .project__title {
    font-size: clamp(1.3rem, 1.1rem + 1vw, 1.75rem);
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
  .project__title a {
    color: var(--ink);
  }
  .project__title a:hover {
    color: var(--forest);
  }
  .project__summary {
    color: var(--ink);
    font-weight: 500;
  }
  .project__excerpt {
    color: var(--ink-soft);
    font-size: 0.96rem;
  }
  .project__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin-top: 0.25rem;
  }
  .project__tags .tag {
    font-size: 0.78rem;
    padding: 0.3rem 0.7rem;
  }
  .project__more {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  @media (max-width: 720px) {
    .project {
      grid-template-columns: 1fr;
    }
  }
</style>
