---
import BaseLayout from '../layouts/BaseLayout.astro';
import SocialLinks from '../components/SocialLinks.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site.ts';
import { withBase, asset } from '../lib/paths.ts';

// Blended hero banner image (configured in site.ts). Transparent PNG that
// blends into the page — no frame/box, same fashion as the About portrait.
const heroImage = site.images.hero ? asset(site.images.hero) : undefined;
const projectsHref = withBase('/projects');
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__inner">
      {
        heroImage && (
          <div class="hero__media">
            <img
              class="hero__image"
              src={heroImage}
              alt={`${site.name} — research highlights`}
            />
          </div>
        )
      }
      <div class="hero__content">
        <div class="hero__top">
          <h1 class="hero__name">
            {site.name.split(' ').map((word) => <span class="hero__name-word">{word}</span>)}
          </h1>
          <p class="hero__role" aria-label={site.role}>
            {
              site.role.split(' · ').map((line) => (
                <span class="hero__role-line">{line}</span>
              ))
            }
          </p>
        </div>
        <div class="hero__social">
          <SocialLinks showLabel />
        </div>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section intro">
    <div class="container">
      <p class="intro__text lead">{site.intro}</p>

      <ul class="intro__tags" aria-label="Research interests">
        {site.researchInterests.map((r) => <li class="tag">{r}</li>)}
      </ul>

      <div class="intro__cta">
        <a href={projectsHref} class="btn btn--primary">
          <Icon name="arrow-right" size={18} /> View Projects
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Typewriter effect for the hero role (two lines). Progressive enhancement:
  // the full text is already in the DOM, so it works fine without JS / with
  // reduced motion; this just re-types it for effect.
  const role = document.querySelector('.hero__role');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (role && !reduce) {
    const lines = Array.from(role.querySelectorAll('.hero__role-line'));
    const texts = lines.map((l) => l.textContent || '');
    lines.forEach((l) => (l.textContent = ''));
    let li = 0;
    let ci = 0;
    const step = () => {
      if (li >= lines.length) return; // finished — caret stays on the last line
      const line = lines[li];
      const full = texts[li];
      lines.forEach((l) => l.classList.remove('has-cursor'));
      line.classList.add('has-cursor');
      if (ci <= full.length) {
        line.textContent = full.slice(0, ci);
        ci += 1;
        setTimeout(step, 55);
      } else {
        li += 1;
        ci = 0;
        setTimeout(step, 260);
      }
    };
    setTimeout(step, 400); // let the name land first
  }
</script>

<style>
  .hero {
    position: relative;
    min-height: min(78vh, 720px);
    display: flex;
    align-items: stretch;
    overflow: hidden;
    background: var(--paper-tint);
  }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr; /* blended image | text */
    align-items: center;
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: clamp(2rem, 6vh, 4.5rem);
    padding-inline: clamp(1.25rem, 5vw, 3.5rem);
    width: 100%;
  }
  /* Anchor the portrait to the bottom of the hero — the negative margin pulls
     it flush with where the hero section ends (the inner's bottom padding). */
  .hero__media {
    align-self: end;
    margin-bottom: calc(-1 * clamp(2rem, 6vh, 4.5rem));
  }
  /* Blended portrait — no box/frame, transparent edges melt into the page.
     Slightly faded for a subtle, professional look. */
  .hero__image {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(88vh, 800px);
    object-fit: contain;
    object-position: bottom;
    opacity: var(--hero-image-opacity);
  }
  .hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    gap: 2.5rem;
    height: 100%;
  }
  .hero__top {
    text-align: right;
  }
  .hero__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.75rem, 5vw + 1.5rem, 6rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  /* Each name word on its own line. */
  .hero__name-word {
    display: block;
  }
  .hero__role {
    margin-top: 1.25rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(0.9rem, 0.8rem + 0.4vw, 1.1rem);
    letter-spacing: 0;
    text-transform: none;
    color: var(--forest);
  }
  /* Two lines of the role, revealed with a typewriter effect. */
  .hero__role-line {
    display: block;
    min-height: 1.35em;
  }
  .hero__role-line.has-cursor::after {
    content: '';
    display: inline-block;
    width: 0.55ch;
    height: 1.02em;
    margin-left: 3px;
    background: currentColor;
    vertical-align: text-bottom;
    animation: hero-caret 1s steps(1) infinite;
  }
  @keyframes hero-caret {
    50% {
      opacity: 0;
    }
  }

  .intro__text {
    max-width: 62ch;
    margin-inline: auto;
    text-align: center;
    color: var(--ink);
    font-size: clamp(1.1rem, 1rem + 0.6vw, 1.35rem);
    line-height: 1.7;
  }
  .intro__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    list-style: none;
    padding: 0;
    margin: 2rem auto 0;
    max-width: 60rem;
  }
  .intro__cta {
    display: flex;
    justify-content: center;
    margin-top: 2.5rem;
  }

  @media (max-width: 820px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__media {
      order: -1; /* image on top when stacked */
      align-self: auto;
      margin-bottom: 0;
    }
    .hero__image {
      max-height: 44vh;
      margin-inline: auto;
    }
    .hero__content {
      align-items: flex-start;
      gap: 1.75rem;
    }
    .hero__top {
      text-align: left;
    }
  }
</style>
