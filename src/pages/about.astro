---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import CertCarousel from '../components/CertCarousel.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site.ts';
import { withBase, asset } from '../lib/paths.ts';

const portrait = site.images.portrait ? asset(site.images.portrait) : undefined;
const resumeHref = asset(site.resume);
---

<BaseLayout title="About">
  <!-- ABOUT ME -->
  <section class="section about">
    <div class="container about__grid">
      <div class="about__text">
        <h1 class="section-kicker">About Me</h1>
        <p class="lead">{site.about}</p>

        <ul class="about__tags" aria-label="Research interests">
          {site.researchInterests.map((r) => <li class="tag">{r}</li>)}
        </ul>

        <a href={resumeHref} class="btn btn--outline" target="_blank" rel="noopener">
          <Icon name="arrow-right" size={18} /> Get My Resume
        </a>
      </div>

      <div class="about__portrait">
        <div class="img-box">
          {portrait ? <img src={portrait} alt={site.name} /> : <span>&lt;IMAGE&gt;</span>}
        </div>
      </div>
    </div>
  </section>

  <!-- THE JOURNEY -->
  <section class="section journey">
    <div class="container">
      <h2 class="section-kicker">The Journey</h2>
      <div class="journey__body">
        <Timeline />
      </div>
    </div>
  </section>

  <!-- CERTIFICATIONS -->
  <section class="section certs">
    <div class="container">
      <h2 class="certs__heading">Certifications<span>/</span></h2>
      <p class="lead certs__intro">
        A selection of courses, workshops and credentials. Replace this line with a short
        description of the certifications shown below.
      </p>
      <CertCarousel />

      <p class="certs__crosslink">
        <Icon name="arrow-right" size={18} /> Check out my
        <a href={withBase('/publications')}>Publications</a> &amp;
        <a href={withBase('/projects')}>Projects</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
  }
  .about__text {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }
  .about__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }
  .about__tags .tag {
    font-size: 0.8rem;
  }
  .about__portrait .img-box {
    aspect-ratio: 4 / 5;
  }

  .journey {
    background: var(--paper-soft);
    border-block: 1px solid var(--line);
  }
  .journey__body {
    margin-top: 2.5rem;
  }

  .certs__heading {
    font-family: var(--font-display);
    font-weight: 700;
    text-align: center;
    font-size: clamp(1.9rem, 1.4rem + 2.5vw, 3.25rem);
    letter-spacing: -0.02em;
  }
  .certs__heading span {
    color: var(--forest);
  }
  .certs__intro {
    text-align: center;
    margin: 1rem auto 2.5rem;
    max-width: 65ch;
  }
  .certs__crosslink {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-weight: 500;
  }
  .certs__crosslink a {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 820px) {
    .about__grid {
      grid-template-columns: 1fr;
    }
    .about__portrait {
      order: -1;
      max-width: 420px;
    }
  }
</style>
