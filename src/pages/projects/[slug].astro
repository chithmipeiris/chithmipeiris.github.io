---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { withBase } from '../../lib/paths.ts';

export async function getStaticPaths() {
  const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order
  );
  return projects.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, next: projects[(i + 1) % projects.length] },
  }));
}

const { entry, next } = Astro.props;
const { Content, headings } = await render(entry);

// Build the on-page section nav from the ## (depth 2) headings in the markdown.
const sections = headings.filter((h) => h.depth === 2);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="section project-detail">
    <div class="container">
      <a href={withBase('/projects')} class="back-link">
        <Icon name="arrow-left" size={18} /> Back to Projects
      </a>

      <header class="project-detail__header">
        <h1>{entry.data.title}</h1>
        <p class="lead">{entry.data.summary}</p>
      </header>

      <hr class="project-detail__rule" />

      <div class="project-detail__layout">
        {
          sections.length > 0 && (
            <aside class="section-nav" aria-label="On this page">
              <p class="section-nav__title">On this page</p>
              <nav>
                <ul>
                  {sections.map((s) => (
                    <li>
                      <a href={`#${s.slug}`}>{s.text}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            </aside>
          )
        }

        <div class="prose">
          <Content />
        </div>
      </div>

      {
        next && next.id !== entry.id && (
          <footer class="read-next">
            <a href={withBase(`/projects/${next.id}`)} class="read-next__link">
              <span class="read-next__label">Read Next</span>
              <span class="read-next__title">
                {next.data.title} <Icon name="arrow-right" size={18} />
              </span>
            </a>
          </footer>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .back-link:hover {
    color: var(--forest);
  }

  .project-detail__header {
    text-align: center;
    max-width: 60ch;
    margin: 2rem auto 0;
  }
  .project-detail__header h1 {
    font-size: clamp(2.2rem, 1.6rem + 3vw, 4rem);
    text-transform: uppercase;
  }
  .project-detail__header .lead {
    margin: 1rem auto 0;
  }
  .project-detail__rule {
    border: none;
    border-top: 1px solid var(--line);
    margin: 2.5rem auto;
    max-width: 720px;
  }

  .project-detail__layout {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }

  .section-nav {
    position: sticky;
    top: 6rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.25rem 1.35rem;
    background: var(--paper-soft);
  }
  .section-nav__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0 0 0.75rem;
  }
  .section-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .section-nav a {
    color: var(--ink-soft);
    font-size: 0.92rem;
    border-left: 2px solid var(--line);
    padding-left: 0.75rem;
    display: block;
  }
  .section-nav a:hover {
    color: var(--forest);
    border-left-color: var(--forest);
  }

  /* Prose (markdown body) */
  .prose {
    max-width: 72ch;
  }
  .prose :global(h2) {
    font-size: clamp(1.4rem, 1.1rem + 1vw, 1.9rem);
    margin: 2.25rem 0 0.75rem;
  }
  .prose :global(h2:first-child) {
    margin-top: 0;
  }
  .prose :global(p) {
    margin: 0 0 1.1rem;
    color: var(--ink-soft);
  }
  .prose :global(img) {
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .prose :global(ul),
  .prose :global(ol) {
    color: var(--ink-soft);
    padding-left: 1.25rem;
    margin: 0 0 1.1rem;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--forest);
    padding-left: 1rem;
    color: var(--ink-soft);
    font-style: italic;
    margin: 1.25rem 0;
  }

  .read-next {
    margin-top: 3.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: flex-end;
  }
  .read-next__link {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.15rem;
    text-align: right;
  }
  .read-next__label {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
  }
  .read-next__title {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--forest);
    font-weight: 500;
  }
  .read-next__link:hover .read-next__title {
    color: var(--moss);
  }

  @media (max-width: 820px) {
    .project-detail__layout {
      grid-template-columns: 1fr;
    }
    .section-nav {
      position: static;
    }
  }
</style>
