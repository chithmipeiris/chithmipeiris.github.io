---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Projects">
  <section class="section">
    <div class="container">
      <h1 class="section-kicker">Projects</h1>
      <figure class="intro-quote">
        <blockquote>“The role of the infinitely small in nature is infinitely large.”</blockquote>
        <figcaption>— Louis Pasteur</figcaption>
      </figure>
      <p class="lead projects__intro">
        This is where curiosity gets its hands dirty. Every project starts with a hunch —
        a pigment glowing in a flask, a microbe clinging to seaweed, DNA locked inside a
        stubborn leaf — and chases it through screening, fermentation and analysis all the
        way to a real result. Poke around: from marine bacterial pigments and sustainable
        fungal dyes to the molecular methods that make the rest possible.
      </p>

      <div class="projects__timeline">
        <div class="projects__rail" aria-hidden="true"></div>
        <ol class="projects__list">
          {
            projects.map((p) => (
              <li class="projects__item">
                <span class="projects__node" aria-hidden="true" />
                <ProjectCard
                  id={p.id}
                  title={p.data.title}
                  summary={p.data.summary}
                  excerpt={p.data.excerpt}
                  cover={p.data.cover}
                  tags={p.data.tags}
                />
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .intro-quote {
    display: table; /* shrink-wrap to the quote's width so the caption can sit at its end */
    margin: 1.5rem 0 1.25rem;
    padding-left: 1.1rem;
    border-left: 3px solid var(--forest);
  }
  .intro-quote blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 0.9rem + 0.8vw, 1.5rem);
    font-style: italic;
    line-height: 1.3;
    margin: 0;
  }
  .intro-quote figcaption {
    margin-top: 0.45rem;
    text-align: right;
    color: var(--forest);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
  }
  .projects__intro {
    margin: 0 0 3rem;
    max-width: 72ch;
    font-style: italic;
  }
  .projects__timeline {
    position: relative;
    padding-left: clamp(2rem, 5vw, 3.5rem);
  }
  .projects__rail {
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 5px;
    width: 2px;
    background: var(--line-strong);
  }
  .projects__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vw, 2.75rem);
  }
  .projects__item {
    position: relative;
  }
  /* Horizontal dash connecting the rail to each card. */
  .projects__node {
    position: absolute;
    top: 2.75rem;
    left: calc(-1 * clamp(2rem, 5vw, 3.5rem) + 6px);
    width: calc(clamp(2rem, 5vw, 3.5rem) - 12px);
    height: 2px;
    background: var(--forest);
  }

  @media (max-width: 620px) {
    .projects__timeline {
      padding-left: 0;
    }
    .projects__rail,
    .projects__node {
      display: none;
    }
  }
</style>
